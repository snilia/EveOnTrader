{
  "family": "eveontrader-web",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "1024",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "executionRoleArn": "arn:aws:iam::774126906739:role/EveOnTraderEcsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "web",
      "image": "774126906739.dkr.ecr.eu-central-1.amazonaws.com/eveontrader-web:bootstrap",
      "essential": true,
      "portMappings": [
        {
          "name": "web-8080-tcp",
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "environment": [
        {
          "name": "ASPNETCORE_ENVIRONMENT",
          "value": "Production"
        },
        {
          "name": "ASPNETCORE_HTTP_PORTS",
          "value": "8080"
        }
      ],
      "secrets": [
        {
          "name": "ConnectionStrings__EveDatabase",
          "valueFrom": "arn:aws:ssm:eu-central-1:774126906739:parameter/eveontrader/prod/connection-string"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/eveontrader/web",
          "awslogs-region": "eu-central-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}