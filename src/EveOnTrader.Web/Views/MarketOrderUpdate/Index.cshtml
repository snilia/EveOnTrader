@model EveOnTrader.Web.Models.MarketOrderUpdateViewModel

@{
    ViewBag.Title = "Market Order Update";

    var regionOptionsJson = System.Text.Json.JsonSerializer.Serialize(
        Model.AvailableRegions
            .OrderBy(x => x.Name)
            .Select(x => new
            {
                id = x.RegionId,
                name = x.Name
            }));
}

<h2>Market Order Update</h2>

<p>
    Source regions download sell orders.<br />
    Destination regions download buy orders.<br />
    Type region IDs, exact region names, or <strong>all</strong>.
</p>

<form method="post" asp-action="Index" class="mb-4">
    @Html.AntiForgeryToken()

    <div class="row g-3 mb-3">
        <div class="col-md-6">
            <label asp-for="SourceRegionIdsText" class="form-label">Source Regions</label>
            <textarea asp-for="SourceRegionIdsText" rows="8" class="form-control"></textarea>
            <div class="form-text">Downloads sell orders for these regions.</div>

            <div class="mt-2">
                <button type="button" class="btn btn-outline-secondary btn-sm me-2 mb-2" onclick="addSourceRegion('10000002')">Add The Forge</button>
                <button type="button" class="btn btn-outline-secondary btn-sm me-2 mb-2" onclick="addSourceRegion('10000043')">Add Domain</button>
                <button type="button" class="btn btn-outline-secondary btn-sm me-2 mb-2" onclick="addSourceRegion('10000032')">Add Sinq Laison</button>
                <button type="button" class="btn btn-outline-secondary btn-sm me-2 mb-2" onclick="addSourceRegion('10000030')">Add Heimatar</button>
                <button type="button" class="btn btn-outline-secondary btn-sm me-2 mb-2" onclick="addSourceRegion('10000042')">Add Metropolis</button>
                <button type="button" class="btn btn-outline-secondary btn-sm me-2 mb-2" onclick="setSourceRegions('all')">All</button>
                <button type="button" class="btn btn-outline-danger btn-sm me-2 mb-2" onclick="clearSourceRegions()">Clear</button>
            </div>

            <div class="mt-3">
                <label class="form-label">Add source by region name</label>
                <div class="input-group">
                    <input id="sourceRegionSearch" list="regionList" type="text" class="form-control" placeholder="Start typing region name..." />
                    <button type="button" class="btn btn-outline-primary" onclick="addSourceRegionFromSearch()">Add</button>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <label asp-for="DestinationRegionIdsText" class="form-label">Destination Regions</label>
            <textarea asp-for="DestinationRegionIdsText" rows="8" class="form-control"></textarea>
            <div class="form-text">Downloads buy orders for these regions.</div>

            <div class="mt-2">
                <button type="button" class="btn btn-outline-secondary btn-sm me-2 mb-2" onclick="addDestinationRegion('10000002')">Add The Forge</button>
                <button type="button" class="btn btn-outline-secondary btn-sm me-2 mb-2" onclick="addDestinationRegion('10000043')">Add Domain</button>
                <button type="button" class="btn btn-outline-secondary btn-sm me-2 mb-2" onclick="addDestinationRegion('10000032')">Add Sinq Laison</button>
                <button type="button" class="btn btn-outline-secondary btn-sm me-2 mb-2" onclick="addDestinationRegion('10000030')">Add Heimatar</button>
                <button type="button" class="btn btn-outline-secondary btn-sm me-2 mb-2" onclick="addDestinationRegion('10000042')">Add Metropolis</button>
                <button type="button" class="btn btn-outline-secondary btn-sm me-2 mb-2" onclick="setDestinationRegions('all')">All</button>
                <button type="button" class="btn btn-outline-danger btn-sm me-2 mb-2" onclick="clearDestinationRegions()">Clear</button>
            </div>

            <div class="mt-3">
                <label class="form-label">Add destination by region name</label>
                <div class="input-group">
                    <input id="destinationRegionSearch" list="regionList" type="text" class="form-control" placeholder="Start typing region name..." />
                    <button type="button" class="btn btn-outline-primary" onclick="addDestinationRegionFromSearch()">Add</button>
                </div>
            </div>
        </div>
    </div>

    <datalist id="regionList">
        @foreach (var region in Model.AvailableRegions.OrderBy(x => x.Name))
        {
            <option value="@region.Name">@region.RegionId</option>
        }
    </datalist>

    <button type="submit" class="btn btn-warning">Update Market Orders</button>
</form>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-warning">
        @Model.ErrorMessage
    </div>
}

@if (Model.Result is not null)
{
    <div class="alert alert-success">
        <strong>Market order update done.</strong>

        <div class="mt-2">
            Selection: @Model.Result.SelectionName<br />
            Batch ID: @Model.Result.ImportBatchId<br />
            Imported at UTC: @Model.Result.ImportedAtUtc.ToString("O")<br />
            Request slices selected: @Model.Result.RequestCount.ToString("N0")<br />
            Normalized request slices: @Model.Result.NormalizedRequestCount.ToString("N0")<br />
            Deleted old market orders: @Model.Result.DeletedMarketOrderCount.ToString("N0")<br />
            Inserted market orders: @Model.Result.InsertedMarketOrderCount.ToString("N0")<br />
            New regions: @Model.Result.RegionsInserted.ToString("N0")<br />
            New solar systems: @Model.Result.SolarSystemsInserted.ToString("N0")<br />
            New market locations: @Model.Result.MarketLocationsInserted.ToString("N0")<br />
            New item refs: @Model.Result.ItemTypeRefsInserted.ToString("N0")<br />
            Elapsed: @Model.Result.Elapsed
        </div>
    </div>
}

<script>
    const regions = @Html.Raw(regionOptionsJson);

    function addSourceRegion(regionId) {
        appendRegion('SourceRegionIdsText', regionId);
    }

    function addDestinationRegion(regionId) {
        appendRegion('DestinationRegionIdsText', regionId);
    }

    function setSourceRegions(value) {
        document.getElementById('SourceRegionIdsText').value = value;
    }

    function setDestinationRegions(value) {
        document.getElementById('DestinationRegionIdsText').value = value;
    }

    function clearSourceRegions() {
        document.getElementById('SourceRegionIdsText').value = '';
    }

    function clearDestinationRegions() {
        document.getElementById('DestinationRegionIdsText').value = '';
    }

    function addSourceRegionFromSearch() {
        addRegionFromSearch('sourceRegionSearch', 'SourceRegionIdsText');
    }

    function addDestinationRegionFromSearch() {
        addRegionFromSearch('destinationRegionSearch', 'DestinationRegionIdsText');
    }

    function addRegionFromSearch(searchElementId, targetElementId) {
        const searchElement = document.getElementById(searchElementId);
        const value = searchElement.value.trim();

        if (value.length === 0) {
            return;
        }

        const region = regions.find(x => x.name.toLowerCase() === value.toLowerCase());

        appendRegion(targetElementId, region ? region.id.toString() : value);
        searchElement.value = '';
    }

    function appendRegion(elementId, value) {
        const element = document.getElementById(elementId);
        const valueText = value.toString();

        if (valueText.toLowerCase() === 'all') {
            element.value = 'all';
            return;
        }

        const parts = element.value
            .split(/[,\n;]+/)
            .map(x => x.trim())
            .filter(x => x.length > 0 && x.toLowerCase() !== 'all');

        if (!parts.includes(valueText)) {
            parts.push(valueText);
        }

        element.value = parts.join('\n');
    }
</script>