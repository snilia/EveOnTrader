@model List<EveOnTrader.Core.ReadModels.OrderListRow>

@{
    ViewBag.Title = "Orders";
}

<h2>Recent Orders (Top 200)</h2>

<table class="table table-striped table-sm">
    <thead>
        <tr>
            <th>Issued</th>
            <th>Type</th>
            <th>Price</th>
            <th>Vol Remain</th>
            <th>Vol Total</th>
            <th>LocationId</th>
            <th>OrderId</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var o in Model)
        {
            <tr>
                <td>@o.Issued</td>
                <td>@o.TypeName</td>
                <td>@o.Price</td>
                <td>@o.VolumeRemain</td>
                <td>@o.VolumeTotal</td>
                <td>@o.LocationId</td>
                <td>@o.OrderId</td>
            </tr>
        }
    </tbody>
</table>