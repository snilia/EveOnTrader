@model EveOnTrader.Core.DealFinding.Models.RouteDealResult

@{
    ViewBag.Title = "Dodixie To Jita Deals";

    decimal? maxTotalBuyCost = ViewBag.MaxTotalBuyCost as decimal?;
    decimal? maxTotalVolumeM3 = ViewBag.MaxTotalVolumeM3 as decimal?;
    decimal? minTotalRoi = ViewBag.MinTotalRoi as decimal?;
    decimal salesTaxRate = ViewBag.SalesTaxRate is decimal tax ? tax : 0m;
}

<h2>Dodixie Hub Sell -> Jita Hub Buy Deals</h2>

<p>
    Source Location: @ViewBag.SourceLocationName (@(Model.SourceLocationId.HasValue ? Model.SourceLocationId.Value.ToString("N0") : "none"))<br />
    Destination Location: @ViewBag.DestinationLocationName (@Model.DestinationLocationId.ToString("N0"))
</p>

<p>
    Max Buy Cost: @(maxTotalBuyCost.HasValue ? maxTotalBuyCost.Value.ToString("N2") : "none")<br />
    Max Volume M3: @(maxTotalVolumeM3.HasValue ? maxTotalVolumeM3.Value.ToString("N2") : "none")<br />
    Min Total ROI: @(minTotalRoi.HasValue ? minTotalRoi.Value.ToString("P2") : "none")<br />
    Sales Tax Rate: @salesTaxRate.ToString("P2")
</p>

<table class="table table-striped table-sm">
    <thead>
        <tr>
            <th>TypeId</th>
            <th>Type</th>
            <th>Steps</th>
            <th>Units</th>
            <th>Buy Cost</th>
            <th>Sell Revenue</th>
            <th>Profit</th>
            <th>ROI</th>
            <th>Profit / M3</th>
            <th>Profit / Jump</th>
            <th>Best Sell</th>
            <th>Best Buy</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            var bestStep = item.Steps.Last();

            <tr>
                <td>@item.TypeId.ToString("N0")</td>
                <td>@item.TypeName</td>
                <td>@item.Steps.Count.ToString("N0")</td>
                <td>@bestStep.TotalUnits.ToString("N0")</td>
                <td>@bestStep.TotalBuyCost.ToString("N2")</td>
                <td>@bestStep.TotalSellRevenue.ToString("N2")</td>
                <td>@bestStep.TotalProfit.ToString("N2")</td>
                <td>@bestStep.TotalRoi.ToString("P2")</td>
                <td>@bestStep.TotalProfitPerVolumeM3.ToString("N2")</td>
                <td>@bestStep.TotalProfitPerJump.ToString("N2")</td>
                <td>@(item.BestSourceSellPrice.HasValue ? item.BestSourceSellPrice.Value.ToString("N2") : "0.00")</td>
                <td>@(item.BestDestinationBuyPrice.HasValue ? item.BestDestinationBuyPrice.Value.ToString("N2") : "0.00")</td>
            </tr>
        }
    </tbody>
</table>
