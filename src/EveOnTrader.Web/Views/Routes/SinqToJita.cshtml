@model EveOnTrader.Core.ReadModels.AllItemTypesOrderRoute

@{
    ViewBag.Title = "Sinq To Jita";
}

<h2>Sinq Sell -> Jita Buy</h2>

<p>
    Source Region: @ViewBag.SourceRegionName (@Model.SourceRegionId)<br />
    Destination Location: @ViewBag.DestinationLocationName (@Model.DestinationLocationId)
</p>

<table class="table table-striped table-sm">
    <thead>
        <tr>
            <th>TypeId</th>
            <th>Type</th>
            <th>Sell Orders</th>
            <th>Buy Orders</th>
            <th>Best Sell</th>
            <th>Best Buy</th>
            <th>Simple Spread</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            var bestSell = item.SourceSellOrders.FirstOrDefault();
            var bestBuy = item.DestinationBuyOrders.FirstOrDefault();
            decimal? simpleSpread = bestSell is not null && bestBuy is not null
                ? bestBuy.Price - bestSell.Price
                : null;

            <tr>
                <td>@item.TypeId</td>
                <td>@item.TypeName</td>
                <td>@item.SourceSellOrders.Count</td>
                <td>@item.DestinationBuyOrders.Count</td>
                <td>@(bestSell is not null ? bestSell.Price : 0)</td>
                <td>@(bestBuy is not null ? bestBuy.Price : 0)</td>
                <td>@(simpleSpread.HasValue ? simpleSpread.Value : 0)</td>
            </tr>
        }
    </tbody>
</table>
